<?xml version="1.0" encoding="utf-8"?>
<executable>
    <category>MIATT.HW04.ocx</category>
    <title>DOG</title>
    <description>
        Applies difference of Gaussians using ITK
    </description>
    <version>97.0</version>
    <documentation-url></documentation-url>
    <license></license>
    <contributor>Hans J. Johnson</contributor>

    <parameters>
        <label>
            Difference of Gaussian Parameters
        </label>
        <description>
            Parameters for DOG
        </description>

        <double>
            <name>sigma1</name>
            <longflag>sigma1</longflag>
            <description>First sigma value</description>
            <label>First sigma value</label>
            <default>1</default>
            <constraints>
                <minimum>.001</minimum>
                <maximum>100</maximum>
                <step>.001</step>
            </constraints>
        </double>

        <double>
            <name>sigma2</name>
            <longflag>sigma2</longflag>
            <description>Second sigma value</description>
            <label>Second sigma value</label>
            <default>1.5</default>
            <constraints>
                <minimum>.001</minimum>
                <maximum>100</maximum>
                <step>.001</step>
            </constraints>
        </double>


    </parameters>

    <parameters>
        <label>IO</label>
        <description>Input/output parameters</description>
        <image>
            <name>inputVolume</name>
            <longflag>inputVolume</longflag>
            <label>Input Volume</label>
            <channel>input</channel>
            <description>Input volume to be filtered</description>
        </image>
        <image>
            <name>outputVolume</name>
            <longflag>outputVolume</longflag>
            <label>Output Volume</label>
            <channel>output</channel>
            <description>Output filtered</description>
        </image>
    </parameters>
</executable>
