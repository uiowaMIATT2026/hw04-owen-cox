<?xml version="1.0" encoding="utf-8"?>
<executable>
    <category>MIATT.HW04.ocx2026</category>
    <title>Gradient AD</title>
    <description>
        Applies Gradient AD using ITK
    </description>
    <version>97.0</version>
    <documentation-url></documentation-url>
    <license></license>
    <contributor>Hans J. Johnson</contributor>

    <parameters>
        <label>
            Gradient Anisotropic Diffusion Parameters
        </label>
        <description>
            Parameters for Gradient AD
        </description>

        <double>
            <name>timeStep</name>
            <longflag>timeStep</longflag>
            <description>Time step</description>
            <label>Time step</label>
            <default>0.0625</default>
            <constraints>
                <minimum>.001</minimum>
                <maximum>1</maximum>
                <step>.001</step>
            </constraints>
        </double>

        <double>
            <name>conductance</name>
            <longflag>conductance</longflag>
            <description>Conductance</description>
            <label>conductance</label>
            <default>2.0</default>
            <constraints>
                <minimum>.001</minimum>
                <maximum>10</maximum>
                <step>.001</step>
            </constraints>
        </double>

        <integer>
            <name>numberOfIterations</name>
            <longflag>iterations</longflag>
            <description>Number of iterations</description>
            <label>Iterations</label>
            <default>1</default>
            <constraints>
                <minimum>1</minimum>
                <maximum>30</maximum>
                <step>1</step>
            </constraints>
        </integer>

        <double>
            <name>sigma</name>
            <longflag>sigma</longflag>
            <description>Sigma value</description>
            <label>Sigma value</label>
            <default>0.0625</default>
            <constraints>
                <minimum>.001</minimum>
                <maximum>10000</maximum>
                <step>.001</step>
            </constraints>
        </double>

    </parameters>

    <parameters>
        <label>IO</label>
        <description>Input/output parameters</description>
        <image>
            <name>inputVolume</name>
            <longflag>inputVolume</longflag>
            <label>Input Volume</label>
            <channel>input</channel>
            <description>Input volume to be filtered</description>
        </image>
        <image>
            <name>outputVolume</name>
            <longflag>outputVolume</longflag>
            <label>Output Volume</label>
            <channel>output</channel>
            <description>Output filtered</description>
        </image>
    </parameters>
</executable>
